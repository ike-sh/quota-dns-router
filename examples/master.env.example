QDR_TELEGRAM_TOKEN=123456:replace-me
QDR_TELEGRAM_ADMIN_ID=123456789
# 可选：逗号分隔的额外管理员 Telegram 用户 ID（与 QDR_TELEGRAM_ADMIN_ID 并列生效）
# QDR_TELEGRAM_ADMIN_IDS=987654321,111222333
# 可选：只读观察者（可查看 Telegram 状态，不可修改配置）
# QDR_TELEGRAM_OBSERVER_IDS=444555666
# DNS 服务商：cloudflare（默认）或 route53
# QDR_DNS_PROVIDER=cloudflare
# Route53 时使用（凭证通过 AWS_ACCESS_KEY_ID 等环境变量或 IAM 角色）
# QDR_AWS_REGION=us-east-1
QDR_MASTER_LISTEN_ADDR=:8080
QDR_MASTER_PUBLIC_API_URL=http://127.0.0.1:8080
QDR_MASTER_DB_PATH=/var/lib/quota-dns-router/master.db
QDR_MASTER_DATA_DIR=/var/lib/quota-dns-router
QDR_MASTER_LOG_DIR=/var/log/quota-dns-router
QDR_TELEGRAM_POLL_TIMEOUT=20s
QDR_CHECK_INTERVAL=60s
QDR_AGENT_OFFLINE_AFTER=300s
QDR_OFFLINE_NOTIFY_AFTER=600s
# 可选：只读 Web 状态面板 /api/status 的 Bearer Token（留空则内网无鉴权开放）
# QDR_STATUS_READONLY_TOKEN=replace-with-random-token